# Neon Postgres connection strings. Both are provided automatically when the
# Neon <-> Vercel integration is enabled on this project; for local dev, copy
# them from the Neon console for your development branch.
#
# Pooled (PgBouncer) connection — used by the app at runtime (lib/db).
DATABASE_URL="postgres://user:password@ep-example-pooler.region.aws.neon.tech/dbname?sslmode=require"

# Direct (unpooled) connection — required for migrations (drizzle-kit) and
# `pnpm db:studio`, which need session-level features PgBouncer doesn't support.
DATABASE_URL_UNPOOLED="postgres://user:password@ep-example.region.aws.neon.tech/dbname?sslmode=require"

# --- Authentication (see docs/auth.md) ---
#
# Secret used to sign the session cookie (JWT). Generate with:
#   openssl rand -base64 32
# Rotating it signs everything out everywhere (break-glass global logout).
SESSION_SECRET="paste-a-random-32+-char-secret-here"

# scrypt hash of the single login password. Generate with:
#   pnpm auth:hash
# The plaintext password is never stored anywhere.
AUTH_PASSWORD_HASH="scrypt.16384.8.1.examplesalt.examplekey"

# Optional. Milliseconds to delay the response on a failed login attempt
# (blunts brute-forcing a bit). Defaults to 1000 if unset; tests override it
# to 0 so they don't wait out the real delay. Leave unset in production.
# AUTH_FAILURE_DELAY_MS=1000

# --- Google Calendar sync (see docs/google-sync.md) ---
#
# OAuth 2.0 client from the Google Cloud Console — create one, add the
# calendar.events + calendar.readonly scopes, and publish the consent screen
# (a client left in "Testing" mode has refresh tokens that silently expire
# after 7 days).
GOOGLE_CLIENT_ID="paste-your-google-oauth-client-id-here"
GOOGLE_CLIENT_SECRET="paste-your-google-oauth-client-secret-here"

# Encrypts stored Google tokens (AES-256-GCM). Generate with:
#   openssl rand -base64 32
GOOGLE_TOKEN_ENCRYPTION_KEY="paste-a-random-32+-byte-base64-key-here"

# Bearer token Vercel Cron sends to /api/cron/calendar-sync. Generate with:
#   openssl rand -base64 32
CRON_SECRET="paste-a-random-secret-here"

# Optional. Overrides the base URL used to build the OAuth redirect and
# webhook address for local/self-hosted setups. Unset, it falls back to
# VERCEL_URL on Vercel or http://localhost:3000 otherwise.
# APP_BASE_URL="http://localhost:3000"
