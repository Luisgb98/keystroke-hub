# Neon Postgres connection strings. Both are provided automatically when the
# Neon <-> Vercel integration is enabled on this project; for local dev, copy
# them from the Neon console for your development branch.
#
# Pooled (PgBouncer) connection — used by the app at runtime (lib/db).
DATABASE_URL="postgres://user:password@ep-example-pooler.region.aws.neon.tech/dbname?sslmode=require"

# Direct (unpooled) connection — required for migrations (drizzle-kit) and
# `pnpm db:studio`, which need session-level features PgBouncer doesn't support.
DATABASE_URL_UNPOOLED="postgres://user:password@ep-example.region.aws.neon.tech/dbname?sslmode=require"
